             <td className=\"p-3 text-center text-gray-400\">{idx + 1}</td>\n\n                {/* KLAS├ûR ADI VE ├çOKLU SE├ç─░M BUTONU */}\n                <td className=\"p-3 font-bold text-gray-800 dark:text-gray-200 flex items-center gap-2 group-hover:text-blue-700 dark:group-hover:text-blue-400\">\n                  {item.klasor_adi}\n                  <button\n                    onClick={(e) => {\n                      e.stopPropagation()\n                      onSelectSameName(item.klasor_adi)\n                    }}\n                    title={`\"${item.klasor_adi}\" ad─▒ndaki t├╝m kay─▒tlar─▒ se├ğ`}\n                    className=\"opacity-0 group-hover:opacity-100 p-1 bg-gray-100 dark:bg-gray-700 hover:bg-blue-100 dark:hover:bg-blue-900/30 text-blue-600 dark:text-blue-400 rounded transition\"\n                  >\n                    <ListFilter size={14} />\n                  </button>\n                </td>\n\n                <td className=\"p-3 text-gray-500 dark:text-gray-400 text-xs\">{item.tipi}</td>\n                <td className=\"p-3 font-bold text-blue-600 dark:text-blue-400 text-center\">\n                  {String(item.yili || '').split('.')[0]}\n                </td>\n                <td className=\"p-3 text-center bg-gray-50 dark:bg-gray-700/50 font-mono dark:text-gray-300\">\n                  {item.klasor_no}\n                </td>\n                <td className=\"p-3 text-gray-700 dark:text-gray-300 text-center font-medium\">\n                  {item.bas_no && item.bitis_no ? `${item.bas_no}-${item.bitis_no}` : '-'}\n                </td>\n                <td className=\"p-3 text-center text-xs\">{item.saklama_suresi}</td>\n                <td className=\"p-3 font-mono text-xs\">{item.dosyalama_kodu}</td>\n                <td\n                  className=\"p-3 text-xs text-gray-500 italic max-w-xs truncate\"\n                  title={item.aciklama}\n                >\n                  {item.aciklama}\n                </td>\n                <td className=\"p-3 text-right\">\n                  <button\n                    onClick={(e) => {\n                      e.stopPropagation()\n                      onEdit(item)\n                    }}\n                    className=\"p-1.5 text-blue-500 hover:bg-blue-100 rounded mr-1\"\n                  >\n                    <Edit2 size={16} />\n                  </button>\n                  <button\n                    onClick={(e) => {\n                      e.stopPropagation()\n                      onDelete(item.id)\n                    }}\n                    className=\"p-1.5 text-red-500 hover:bg-red-100 rounded\"\n                  >\n                    <Trash2 size={16} />\n                  </button>\n                </td>\n              </tr>\n            ))}\n          </tbody>\n        </table>\n      </div>\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\hakan\\Desktop\\my-super-app\\src\\renderer\\src\\modules\\arsiv\\components\\ArsivToolbar.tsx","messages":[{"ruleId":"@typescript-eslint/explicit-function-return-type","severity":2,"message":"Missing return type on function.","line":17,"column":23,"nodeType":"ArrowFunctionExpression","messageId":"missingReturnType","endLine":17,"endColumn":25}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { Plus, Edit2, Trash2, Printer } from 'lucide-react'\n\ninterface ArsivToolbarProps {\n  onAdd: () => void\n  selectedCount: number\n  onBulkUpdate: () => void\n  onBulkDelete: () => void\n  onReport: () => void\n}\n\nexport const ArsivToolbar = ({\n  onAdd,\n  selectedCount,\n  onBulkUpdate,\n  onBulkDelete,\n  onReport\n}: ArsivToolbarProps) => {\n  return (\n    <div className=\"bg-gray-200 dark:bg-gray-800/50 p-2 border-b dark:border-gray-700 flex gap-2 shadow-inner shrink-0\">\n      <button\n        onClick={onAdd}\n        className=\"flex items-center gap-2 px-4 py-2 bg-white dark:bg-gray-700 border border-gray-400 dark:border-gray-600 rounded hover:bg-blue-50 dark:hover:bg-blue-900/20 text-sm font-bold text-gray-700 dark:text-gray-200 shadow-sm transition\"\n      >\n        <Plus size={16} className=\"text-green-600 dark:text-green-400\" /> Ekle [Insert]\n      </button>\n      {selectedCount > 0 && (\n        <>\n          <button\n            onClick={onBulkUpdate}\n            className=\"flex items-center gap-2 px-4 py-2 bg-orange-600 border border-orange-700 rounded text-white text-sm font-bold shadow-sm transition animate-pulse\"\n          >\n            <Edit2 size={16} /> {selectedCount} G├╝ncelle\n          </button>\n          <button\n            onClick={onBulkDelete}\n            className=\"flex items-center gap-2 px-4 py-2 bg-red-600 border border-red-700 rounded text-white text-sm font-bold shadow-sm transition hover:bg-red-700\"\n          >\n            <Trash2 size={16} /> {selectedCount} Sil\n          </button>\n        </>\n      )}\n      <div className=\"w-px bg-gray-400 dark:bg-gray-600 mx-2\"></div>\n      <button\n        onClick={onReport}\n        className=\"flex items-center gap-2 px-4 py-2 bg-white dark:bg-gray-700 border border-gray-400 dark:border-gray-600 rounded hover:bg-blue-50 dark:hover:bg-blue-900/20 text-sm font-bold text-gray-700 dark:text-gray-200 shadow-sm transition\"\n      >\n        <Printer size={16} className=\"text-blue-600 dark:text-blue-400\" /> Raporla ve Yazd─▒r\n      </button>\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\hakan\\Desktop\\my-super-app\\src\\renderer\\src\\modules\\arsiv\\models\\arsiv-types.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\hakan\\Desktop\\my-super-app\\src\\renderer\\src\\modules\\arsiv\\viewmodels\\useArsivViewModel.ts","messages":[{"ruleId":"@typescript-eslint/explicit-function-return-typ