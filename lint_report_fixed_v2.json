tialData.atanma_tarihi.split('T')[0] : '',\n        terfi_tarihi: initialData.terfi_tarihi ? initialData.terfi_tarihi.split('T')[0] : '',\n        sonraki_terfi: initialData.sonraki_terfi ? initialData.sonraki_terfi.split('T')[0] : ''\n      })\n    } else {\n      // Yeni kay─▒t\n      setForm({\n        ad_soyad: '',\n        sicil_no: '',\n        unvan: '',\n        kadro: '',\n        derece: '',\n        kademe: '',\n        ek_gosterge: '',\n        atanma_tarihi: '',\n        terfi_tarihi: '',\n        terfi_suresi: 12,\n        sonraki_terfi: '',\n        aciklama: '',\n        departman: ''\n      })\n    }\n  }, [initialData, isOpen])\n\n  if (!isOpen) return null\n\n  const handleChange = (\n    e: React.ChangeEvent<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>\n  ) => {\n    setForm({ ...form, [e.target.name]: e.target.value })\n  }\n\n  const handleSubmit = (e: React.FormEvent) => {\n    e.preventDefault()\n    onSave(form)\n  }\n\n  return (\n    <div className=\"fixed inset-0 z-[70] flex items-center justify-center p-4\">\n      <div className=\"absolute inset-0 bg-black/50 backdrop-blur-sm\" onClick={onClose} />\n\n      <div className=\"relative bg-white dark:bg-gray-800 rounded-2xl shadow-2xl w-full max-w-2xl max-h-[90vh] flex flex-col overflow-hidden animate-in fade-in zoom-in-95 duration-200 transition-colors\">\n        {/* Header */}\n        <div className=\"bg-indigo-600 px-6 py-4 flex justify-between items-center text-white shrink-0\">\n          <h2 className=\"text-xl font-bold flex items-center gap-2\">\n            <UserCheck size={24} /> {initialData ? 'Personel D├╝zenle' : 'Personel Ekle'}\n          </h2>\n          <button onClick={onClose} className=\"p-1 hover:bg-white/20 rounded-full transition\">\n            <X size={24} />\n          </button>\n        </div>\n\n        {/* Content */}\n        <form\n          onSubmit={handleSubmit}\n          className=\"flex-1 overflow-y-auto p-6 bg-gray-50/50 dark:bg-gray-90