pe parameters that you don't need to know the type of."}],"suppressions":[{"kind":"directive","justification":""}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":709,"column":42,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":709,"endColumn":45,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[21542,21545],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[21542,21545],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}],"suppressions":[{"kind":"directive","justification":""}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":726,"column":65,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":726,"endColumn":68,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[22058,22061],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[22058,22061],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}],"suppressions":[{"kind":"directive","justification":""}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":733,"column":43,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":733,"endColumn":46,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[22261,22264],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[22261,22264],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}],"suppressions":[{"kind":"directive","justification":""}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":733,"column":57,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":733,"endColumn":60,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[22275,22278],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[22275,22278],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}],"suppressions":[{"kind":"directive","justification":""}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":743,"column":50,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":743,"endColumn":53,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[22573,22576],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[22573,22576],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}],"suppressions":[{"kind":"directive","justification":""}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":905,"column":52,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":905,"endColumn":55,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[25752,25755],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[25752,25755],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}],"suppressions":[{"kind":"directive","justification":""}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":910,"column":58,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":910,"endColumn":61,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[25948,25951],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[25948,25951],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}],"suppressions":[{"kind":"directive","justification":""}]}],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"/* eslint-disable @typescript-eslint/no-explicit-any */\nimport { db } from './firebaseConfig'\nimport {\n  collection,\n  getDocs,\n  addDoc,\n  updateDoc,\n  deleteDoc,\n  doc,\n  query,\n  where,\n  orderBy,\n  limit,\n  setDoc,\n  getDoc,\n  writeBatch\n} from 'firebase/firestore'\n\n// --- YARDIMCI FONS─░YONLAR ---\n\n// Firestore verisini d├╝zg├╝n formatlamak i├ğin (id'yi objeye ekle)\nconst formatDoc = (doc: any) => ({ id: doc.id, ...doc.data() })\n\nexport function initDatabase(userDataPath: string): void {\n  console.log('Firebase Firestore Kullan─▒l─▒yor. Yerel veritaban─▒ dosyas─▒ gerekmez:', userDataPath)\n}\n\n// --- HARCAMALAR ---\n\nexport async function getHarcamalarByMonth(params: any): Promise<any[]> {\n  const colRef = collection(db, 'harcamalar')\n  let q\n\n  if (typeof params === 'object' && params.baslangic && params.bitis) {\n    q = query(\n      colRef,\n      where('tarih', '>=', params.baslangic),\n      where('tarih', '<=', params.bitis),\n      orderBy('tarih', 'desc')\n    )\n  } else {\n    // String gelirse (├Âr: \"2024-01\") startAt/endAt yerine string aramas─▒ Firestore'da tam desteklenmez\n    // Bu y├╝zden basit├ğe o ay─▒ kapsayan bir aral─▒k olu┼şturuyoruz\n    const startStr = params + '-01'\n    const endStr = params + '-31' // Basit yakla┼ş─▒m\n    q = query(\n      colRef,\n      where('tarih', '>=', startStr),\n      where('tarih', '<=', endStr),\n      orderBy('tarih', 'desc')\n    )\n  }\n\n  const snapshot = await getDocs(q)\n  // Client taraf─▒nda s─▒ralama garanti olsun diye tekrar sort edilebilir ama orderBy halleder\n  return snapshot.docs.map(formatDoc)\n}\n\nexport async function getDevirBakiyesi(tarihBaslangic: string): Promise<number> {\n  // Firestore'da SUM i┼şlemi i├ğin aggregation query gerekir veya t├╝m├╝n├╝ ├ğekip toplan─▒r.\n  // Basitlik ve h─▒z i├ğin ┼şimdilik ├Ânceki t├╝m kay─▒tlar─▒ ├ğekip topluyoruz.\n  // Performans sorunu olursa \"Devir\" diye ayr─▒ bir koleksiyon tutulmal─▒.\n  const colRef = collection(db, 'harcamalar')\n  const q = query(colRef, where('tarih', '<', tarihBaslangic))\n  const snapshot = await getDocs(q)\n\n  let gelir = 0\n  let gider = 0\n\n  snapshot.forEach((doc) => {\n    const data = doc.data()\n    if (data.tur === 'GELIR') gelir += Number(data.tutar)\n    if (data.tur === 'GIDER') gider += Number(data.tutar)\n  })\n\n  return gelir - gider\n}\n\nexport async function addHarcama(data: any): Promise<any> {\n  const colRef = collection(db, 'harcamalar')\n  const res = await addDoc(colRef, {\n    baslik: data.baslik,\n    tutar: Number(data.tutar),\n    tarih: data.tarih,\n    kategori: data.kategori,\n    tur: data.tur\n  })\n  return { id: res.id, ...data }\n}\n\nexport async function updateHarcama(data: any): Promise<boolean> {\n  const docRef = doc(db, 'harcamalar', data.id)\n  await updateDoc(docRef, {\n    baslik: data.baslik,\n    tutar: Number(data.tutar),\n    tarih: data.tarih,\n    kategori: data.kategori,\n    tur: data.tur\n  })\n  return true\n}\n\nexport async function deleteHarcama(id: string): Promise<boolean> {\n  await deleteDoc(doc(db, 'harcamalar', id))\n  return true\n}\n\n// --- HARCAMA AYARLARI (PERSONEL & G─░ZLENENLER) ---\n\nexport async function getHarcamaPersonelleri(): Promise<any[]> {\n  const snapshot = await getDocs(\n    query(collection(db, 'harcama_sabit_personeller'), orderBy('ad_soyad', 'asc'))\n  )\n  return snapshot.docs.map(formatDoc)\n}\n\nexport async function getHarcamaSabitPersoneller(): Promise<any[]> {\n  return await getHarcamaPersonelleri()\n}\n\nexport async function addHarcamaSabitPersonel(adSoyad: string): Promise<any> {\n  const res = await addDoc(collection(db, 'harcama_sabit_personeller'), { ad_soyad: adSoyad })\n  return { id: res.id, ad_soyad: adSoyad }\n}\n\nexport async function deleteHarcamaSabitPersonel(id: string): Promise<boolean> {\n  await deleteDoc(doc(db, 'harcama_sabit_personeller', id))\n  return true\n}\n\nexport async function addHarcamaYerelKisi(adSoyad: string): Promise<any> {\n  const res = await addDoc(collection(db, 'harcama_yerel_kisiler'), { ad_soyad: adSoyad })\n  return { id: res.id, ad_soyad: adSoyad }\n}\n\nexport async function deleteHarcamaGorunum(\n  id: string,\n  kaynak: 'GLOBAL' | 'YEREL'\n): Promise<boolean> {\n  if (kaynak === 'YEREL') {\n    await deleteDoc(doc(db, 'harcama_yerel_kisiler', id))\n  } else {\n    // Global personeli yerel g├Âr├╝n├╝mde gizle (ayr─▒ koleksiyon)\n    await addDoc(collection(db, 'harcama_gizlenenler'), { personel_id: id })\n  }\n  return true\n}\n\n// --- PERSONELLER ---\n\nexport async function getPersoneller(): Promise<any[]> {\n  const snapshot = await getDocs(query(collection(db, 'personeller'), orderBy('ad_soyad', 'asc')))\n  return snapshot.docs.map(formatDoc)\n}\n\nexport async function addPersonel(data: any): Promise<any> {\n  const res = await addDoc(collection(db, 'personeller'), data)\n  return { id: res.id, ...data }\n}\n\nexport async function updatePersonel(data: any): Promise<boolean> {\n  const { id, ...updateData } = data\n  await updateDoc(doc(db, 'personeller', id), updateData)\n  return true\n}\n\nexport async function deletePersonel(id: string): Promise<boolean> {\n  await deleteDoc(doc(db, 'personeller', id))\n  return true\n}\n\n// --- REHBER ---\n\nexport async function getRehber(): Promise<any[]> {\n  const snapshot = await getDocs(query(collection(db, 'rehber'), orderBy('ad_soyad', 'asc')))\n  return snapshot.docs.map(formatDoc)\n}\n\nexport async function addRehber(data: any): Promise<any> {\n  const res = await addDoc(collection(db, 'rehber'), data)\n  return { id: res.id, ...data }\n}\n\nexport async function updateRehber(data: any): Promise<boolean> {\n  const { id, ...updateData } = data\n  await updateDoc(doc(db, 'rehber', id), updateData)\n  return true\n}\n\nexport async function deleteRehber(id: string): Promise<boolean> {\n  await deleteDoc(doc(db, 'rehber', id))\n  return true\n}\n\n// --- ZIMMET ---\n\nexport async function getZimmet(limitVal = 100): Promise<any[]> {\n  const q = query(collection(db, 'zimmet'), orderBy('id', 'desc'), limit(limitVal)) // ID s─▒ralamas─▒ Firestore'da auto-id oldu─şu i├ğin tarih kullan─▒lmal─▒\n  // Ancak mevcut yap─▒da ID'ye g├╝venilmi┼ş. Firestore'da 'createdAt' alan─▒ ekleyip ona g├Âre s─▒ralamak en do─şrusu.\n  // Migration s─▒ras─▒nda mevcut veriye dokunmuyoruz ama yeni kay─▒tlarda tarih alan─▒ zaten var.\n  // Ge├ğici olarak tarih'e g├Âre s─▒ralayal─▒m:\n  // NOT: E─şer tarih alan─▒ string 'YYYY-MM-DD' ise alfabetik s─▒ralama i┼şe yarar.\n  // const qSorted = query(collection(db, 'zimmet'), orderBy('tarih', 'desc'), limit(limitVal));\n  const snapshot = await getDocs(q)\n  return snapshot.docs.map(formatDoc)\n}\n\nexport async function addZimmet(data: any): Promise<any> {\n  const res = await addDoc(collection(db, 'zimmet'), {\n    ...data,\n    durum: 'BEKL─░YOR',\n    createdAt: new Date().toISOString() // S─▒ralama i├ğin eklenebilir\n  })\n  return { id: res.id, ...data }\n}\n\nexport async function updateZimmetDurum(id: string, durum: string): Promise<boolean> {\n  await updateDoc(doc(db, 'zimmet', id), { durum })\n  return true\n}\n\nexport async function deleteZimmet(id: string): Promise<boolean> {\n  await deleteDoc(doc(db, 'zimmet', id))\n  return true\n}\n\nexport async function searchZimmet(term: string): Promise<any[]> {\n  // Firestore'da \"LIKE %Query%\" sorgusu yoktur. Tam metin arama i├ğin Algolia vb. ├Ânerilir.\n  // Basit ├ğ├Âz├╝m: Client-side filtreleme veya \"orderBy\" ve \"startAt\" kullanma (sadece prefix aramas─▒ yapar).\n  // ┼Şimdilik t├╝m├╝n├╝ ├ğekip JS ile filtreleyelim (Veri az varsay─▒m─▒yla)\n  if (!term) return []\n  const snapshot = await getDocs(collection(db, 'zimmet'))\n  const all = snapshot.docs.map(formatDoc)\n  const lower = term.toLowerCase()\n  return all.filter(\n    (z: any) =>\n      (z.barkod && z.barkod.toLowerCase().includes(lower)) ||\n      (z.evrak_no && z.evrak_no.toLowerCase().includes(lower)) ||\n      (z.yer && z.yer.toLowerCase().includes(lower))\n  )\n}\n\n// --- RESM─░ YAZI (EVRAKLAR) ---\n\nexport async function getEvraklar(): Promise<any[]> {\n  const snapshot = await getDocs(query(collection(db, 'evraklar'), orderBy('tarih', 'desc')))\n  return snapshot.docs.map(formatDoc)\n}\n\nexport async function addEvrak(data: any): Promise<any> {\n  const res = await addDoc(collection(db, 'evraklar'), data)\n  return { id: res.id, ...data }\n}\n\nexport async function updateEvrak(data: any): Promise<boolean> {\n  const { id, ...updateData } = data\n  await updateDoc(doc(db, 'evraklar', id), updateData)\n  return true\n}\n\nexport async function deleteEvrak(id: string): Promise<boolean> {\n  await deleteDoc(doc(db, 'evraklar', id))\n  return true\n}\n\n// --- E─Ş─░T─░M ---\n\nexport async function getEgitimKonular(): Promise<any[]> {\n  const snapshot = await getDocs(collection(db, 'egitim_konular'))\n  // ID s─▒ralamas─▒ yerine olu┼şturma s─▒ras─▒ veya alfabetik\n  return snapshot.docs.map(formatDoc).sort((a: any, b: any) => a.baslik?.localeCompare(b.baslik))\n}\n\nexport async function addEgitimKonu(baslik: string): Promise<any> {\n  const res = await addDoc(collection(db, 'egitim_konular'), { baslik })\n  return { id: res.id, baslik }\n}\n\nexport async function deleteEgitimKonu(id: string): Promise<boolean> {\n  await deleteDoc(doc(db, 'egitim_konular', id))\n  return true\n}\n\nexport async function updateEgitimKonu(id: string, baslik: string): Promise<boolean> {\n  await updateDoc(doc(db, 'egitim_konular', id), { baslik })\n  return true\n}\n\nexport async function getEgitimEgiticiler(): Promise<any[]> {\n  const snapshot = await getDocs(\n    query(collection(db, 'egitim_egiticiler'), orderBy('ad_soyad', 'asc'))\n  )\n  return snapshot.docs.map(formatDoc)\n}\n\nexport async function addEgitimEgitici(data: any): Promise<any> {\n  const res = await addDoc(collection(db, 'egitim_egiticiler'), {\n    ad_soyad: data.ad,\n    unvan: data.unvan\n  })\n  return { id: res.id, ...data }\n}\n\nexport async function updateEgitimEgitici(data: any): Promise<boolean> {\n  await updateDoc(doc(db, 'egitim_egiticiler', data.id), { ad_soyad: data.ad, unvan: data.unvan })\n  return true\n}\n\nexport async function deleteEgitimEgitici(id: string): Promise<boolean> {\n  await deleteDoc(doc(db, 'egitim_egiticiler', id))\n  return true\n}\n\nexport async function getEgitimPersoneller(): Promise<any[]> {\n  const snapshot = await getDocs(\n    query(collection(db, 'egitim_personeller'), orderBy('ad_soyad', 'asc'))\n  )\n  return snapshot.docs.map(formatDoc)\n}\n\nexport async function addEgitimPersonel(data: any): Promise<any> {\n  const res = await addDoc(collection(db, 'egitim_personeller'), {\n    ad_soyad: data.ad,\n    unvan: data.unvan,\n    cinsiyet: data.cinsiyet,\n    grup: data.grup || 'Sabah'\n  })\n  return { id: res.id, ...data }\n}\n\nexport async function updateEgitimPersonel(data: any): Promise<boolean> {\n  await updateDoc(doc(db, 'egitim_personeller', data.id), {\n    ad_soyad: data.ad,\n    unvan: data.unvan,\n    cinsiyet: data.cinsiyet,\n    grup: data.grup\n  })\n  return true\n}\n\nexport async function deleteEgitimPersonel(id: string): Promise<boolean> {\n  await deleteDoc(doc(db, 'egitim_personeller', id))\n  return true\n}\n\n// Planlar ve Dersler (─░li┼şkisel Yap─▒ -> Alt Koleksiyon veya Referans)\n// Basitlik i├ğin: Plan dok├╝man─▒ i├ğinde dersleri array olarak tutabiliriz\n// VEYA egitim_dersler diye ayr─▒ koleksiyon yap─▒p plan_id ile sorgular─▒z.\nexport async function getEgitimPlanlar(): Promise<any[]> {\n  const snapshot = await getDocs(\n    query(collection(db, 'egitim_planlar'), orderBy('olusturma_tarihi', 'desc'))\n  )\n  return snapshot.docs.map(formatDoc)\n}\n\nexport async function saveEgitimPlan(data: any): Promise<boolean> {\n  const batch = writeBatch(db)\n\n  // Plan─▒ olu┼ştur\n  const planRef = doc(collection(db, 'egitim_planlar'))\n  batch.set(planRef, { adi: data.adi, olusturma_tarihi: data.tarih })\n\n  // Dersleri ayr─▒ koleksiyona ekle (Batch ile)\n  data.dersler.forEach((ders: any) => {\n    const dersRef = doc(collection(db, 'egitim_dersler'))\n    batch.set(dersRef, {\n      plan_id: planRef.id,\n      konu: ders.konu,\n      egitici: ders.egitici,\n      tarih: ders.tarih,\n      saat: ders.saat\n    })\n  })\n\n  await batch.commit()\n  return true\n}\n\nexport async function deleteEgitimPlan(id: string): Promise<boolean> {\n  // ├ûnce dersleri sil\n  const derslerQ = query(collection(db, 'egitim_dersler'), where('plan_id', '==', id))\n  const derslerSnap = await getDocs(derslerQ)\n\n  const batch = writeBatch(db)\n  derslerSnap.forEach((d) => batch.delete(d.ref))\n\n  // Plan─▒ sil\n  batch.delete(doc(db, 'egitim_planlar', id))\n\n  await batch.commit()\n  return true\n}\n\nexport async function getEgitimPlanDetay(planId: string): Promise<any> {\n  const planDoc = await getDoc(doc(db, 'egitim_planlar', planId))\n  const plan = formatDoc(planDoc)\n\n  const derslerQ = query(\n    collection(db, 'eg