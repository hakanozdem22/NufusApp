ame=\"text-xs font-bold text-gray-500 dark:text-gray-400\">Durum</label>\n              <select\n                className=\"w-full border p-2 rounded bg-white dark:bg-gray-700 border-gray-200 dark:border-gray-600 text-gray-900 dark:text-white outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-colors\"\n                value={formData.durum}\n                onChange={(e) => setFormData({ ...formData, durum: e.target.value as any })}\n              >\n                <option>Cevap Gerekmiyor</option>\n                <option>Cevap Bekleniyor</option>\n                <option>Cevapland─▒</option>\n              </select>\n            </div>\n          </div>\n          <div className=\"grid grid-cols-2 gap-3\">\n            <div>\n              <label className=\"text-xs font-bold text-gray-500 dark:text-gray-400\">Tarih</label>\n              <input\n                className=\"w-full border p-2 rounded bg-white dark:bg-gray-700 border-gray-200 dark:border-gray-600 text-gray-900 dark:text-white outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-colors\"\n                value={formData.tarih}\n                onChange={(e) => setFormData({ ...formData, tarih: e.target.value })}\n              />\n            </div>\n            <div>\n              <label className=\"text-xs font-bold text-gray-500 dark:text-gray-400\">\n                Say─▒ / No\n              </label>\n              <input\n                className=\"w-full border p-2 rounded bg-white dark:bg-gray-700 border-gray-200 dark:border-gray-600 text-gray-900 dark:text-white outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-colors\"\n                value={formData.sayi}\n                onChange={(e) => setFormData({ ...formData, sayi: e.target.value })}\n              />\n            </div>\n          </div>\n          <div>\n            <label className=\"text-xs font-bold text-gray-500 dark:text-gray-400\">\n              Kurum / Muhatap\n            </label>\n            <input\n              className=\"w-full border p-2 rounded bg-white dark:bg-gray-700 border-gray-200 dark:border-gray-600 text-gray-900 dark:text-white outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-colors\"\n              value={formData.kurum}\n              onChange={(e) => setFormData({ ...formData, kurum: e.target.value })}\n              required\n              list=\"kurumlar\"\n            />\n            <datalist id=\"kurumlar\">\n              {kurumListesi.map((k) => (\n                <option key={k.id} value={k.ad} />\n              ))}\n            </datalist>\n          </div>\n          <div>\n            <label className=\"text-xs font-bold text-gray-500 dark:text-gray-400\">Konu</label>\n            <textarea\n              className=\"w-full border p-2 rounded h-20 resize-none bg-white dark:bg-gray-700 border-gray-200 dark:border-gray-600 text-gray-900 dark:text-white outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-colors\"\n              value={formData.konu}\n              onChange={(e) => setFormData({ ...formData, konu: e.target.value })}\n              required\n            />\n          </div>\n\n          <div>\n            <label className=\"text-xs font-bold text-gray-500 dark:text-gray-400\">Dosya Eki</label>\n            <div className=\"flex gap-2\">\n              <input\n                className=\"w-full border p-2 rounded bg-gray-50 dark:bg-gray-700/50 border-gray-200 dark:border-gray-600 text-gray-500 dark:text-gray-400 outline-none transition-colors\"\n                value={formData.dosya_yolu}\n                readOnly\n                placeholder=\"Dosya se├ğilmedi\"\n              />\n              <button\n                type=\"button\"\n                onClick={onFileSelect}\n                className=\"px-3 bg-gray-200 dark:bg-gray-600 hover:bg-gray-300 dark:hover:bg-gray-500 text-gray-700 dark:text-gray-200 rounded transition-colors\"\n              >\n                <Upload size={18} />\n              </button>\n            </div>\n          </div>\n\n          <div className=\"flex gap-3 pt-4 border-t dark:border-gray-700 mt-2 transition-colors\">\n            <button\n              type=\"button\"\n              onClick={onClose}\n              className=\"flex-1 py-2 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-200 rounded-lg font-bold hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors\"\n            >\n              ─░ptal\n            </button>\n            <button\n              type=\"submit\"\n              className=\"flex-1 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-bold transition-colors\"\n            >\n              Kaydet\n            </button>\n          </div>\n        </form>\n      </div>\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\hakan\\Desktop\\my-super-app\\src\\renderer\\src\\modules\\resmi_yazi\\components\\EvrakHeader.tsx","messages":[{"ruleId":"@typescript-eslint/explicit-function-return-type","severity":2,"message":"Missing return type on function.","line":9,"column":79,"nodeType":"ArrowFunctionExpression","messageId":"missingReturnType","endLine":9,"endColumn":81}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { Printer, Plus, Loader2 } from 'lucide-react'\n\ninterface EvrakHeaderProps {\n  onPrint: () => void\n  onNew: () => void\n  yukleniyor: boolean\n}\n\nexport const EvrakHeader = ({ onPrint, onNew, yukleniyor }: EvrakHeaderProps) => {\n  return (\n    <div className=\"mx-4 mt-4 p-4 bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm flex justify-between items-center transition-colors\">\n      <div>\n        <h1 className=\"text-xl font-bold text-gray-800 dark:text-white\">Resmi Yaz─▒ Takip</h1>\n        <p className=\"text-xs text-gray-500 dark:text-gray-400\">Gelen/Giden Evrak Y├Ânetimi</p>\n      </div>\n      <div className=\"flex gap-2\">\n        <button\n          onClick={onPrint}\n          disabled={yukleniyor}\n          className=\"bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg flex items-center gap-2 text-sm font-bold shadow-sm transition\"\n        >\n          {yukleniyor ? <Loader2 className=\"animate-spin\" /> : <Printer size={18} />} Listeyi Yazd─▒r\n        </button>\n        <button\n          onClick={onNew}\n          className=\"bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg flex items-center gap-2 text-sm font-bold shadow-sm transition\"\n        >\n          <Plus size={18} /> Yeni Evrak\n        </button>\n      </div>\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\hakan\\Desktop\\my-super-app\\src\\renderer\\src\\modules\\resmi_yazi\\components\\EvrakListTable.tsx","messages":[{"ruleId":"@typescript-eslint/explicit-function-return-type","severity":2,"message":"Missing return type on function.","line":11,"column":93,"nodeType":"ArrowFunctionExpression","messageId":"missingReturnType","endLine":11,"endColumn":95}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { CheckCircle, Clock, FolderOpen, Edit2, Trash2 } from 'lucide-react'\nimport { Evrak } from '../models/evrak-types'\n\ninterface EvrakListTableProps {\n  data: Evrak[]\n  onOpenFile: (path: string) => void\n  onEdit: (evrak: Evrak) => void\n  onDelete: (id: number) => void\n}\n\nexport const EvrakListTable = ({ data, onOpenFile, onEdit, onDelete }: EvrakListTableProps) => {\n  return (\n    <div className=\"mx-6 mt-4 mb-6 bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm flex-1 overflow-auto\">\n      <table className=\"w-full text-sm text-left\">\n        <thead className=\"bg-gray-50 dark:bg-gray-700/50 text-gray-700 dark:text-gray-200 font-bold uppercase text-xs sticky top-0 z-10 shadow-sm\">\n          <tr>\n            <th className=\"p-3 text-center\">T├╝r</th>\n            <th className=\"p-3 text-center\">Tarih</th>\n            <th className=\"p-3 text-center\">Say─▒</th>\n            <th className=\"p-3 text-center\">Kurum</th>\n            <th className=\"p-3 text-center\">Konu</th>\n            <th className=\"p-3 text-center\">Durum</th>\n            <th className=\"p-3 text-center\">─░┼şlem</th>\n          </tr>\n        </thead>\n        <tbody className=\"divide-y dark:divide-gray-700\">\n          {data.map((evrak) => (\n            <tr key={evrak.id} className=\"hover:bg-gray-50 dark:hover:bg-gray-700/30 text-center\">\n              <td className=\"p-3\">\n                <span\n                  className={`px-2 py-1 rounded text-xs font-bold ${evrak.tur === 'Gelen Evrak' ? 'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300' : 'bg-orange-100 dark:bg-orange-900/30 text-orange-700 dark:text-orange-300'}`}\n                >\n                  {evrak.tur}\n                </span>\n              </td>\n              <td className=\"p-3 text-gray-700 dark:text-gray-300\">{evrak.tarih}</td>\n              <td className=\"p-3 font-mono text-gray-600 dark:text-gray-400\">{evrak.sayi}</td>\n              <td className=\"p-3 font-medium text-gray-800 dark:text-gray-200\">{evrak.kurum}</td>\n              <td\n                className=\"p-3 text-gray-600 dark:text-gray-400 truncate max-w-xs text-left\"\n                title={evrak.konu}\n              >\n                {evrak.konu}\n              </td>\n              <td className=\"p-3 flex justify-center\">\n                {evrak.durum === 'Cevap Bekleniyor' && (\n                  <span className=\"text-red-600 flex items-center gap-1\">\n                    <Clock size={14} /> Bekliyor\n                  </span>\n                )}\n                {evrak.durum === 'Cevapland─▒' && (\n                  <span className=\"text-green-600 flex items-center gap-1\">\n                    <CheckCircle size={14} /> Tamam\n                  </span>\n                )}\n                {evrak.durum === 'Cevap Gerekmiyor' && <span className=\"text-gray-400\">-</span>}\n              </td>\n              <td className=\"p-3\">\n                <div className=\"flex justify-center gap-1\">\n                  {evrak.dosya_yolu && (\n                    <button\n                      onClick={() => onOpenFile(evrak.dosya_yolu)}\n                      className=\"p-1.5 text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded\"\n                      title=\"Dosyay─▒ A├ğ\"\n                    >\n                      <FolderOpen size={16} />\n                    </button>\n                  )}\n                  <button\n                    onClick={() => onEdit(evrak)}\n                    className=\"p-1.5 text-blue-600 dark:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded\"\n                  >\n                    <Edit2 size={16} />\n                  </button>\n                  <button\n                    onClick={() => onDelete(evrak.id!)}\n                    className=\"p-1.5 text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 rounded\"\n                  >\n                    <Trash2 size={16} />\n                  </button>\n                </div>\n              </td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\hakan\\Desktop\\my-super-app\\src\\renderer\\src\\modules\\resmi_yazi\\models\\evrak-types.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\hakan\\Desktop\\my-super-app\\src\\renderer\\src\\modules\\resmi_yazi\\viewmodels\\useResmiYaziViewModel.ts","messages":[{"ruleId":"@typescript-eslint/explicit-function-return-type","severity":2,"message":"Missing return type on function.","line":4,"column":41,"nodeType":"ArrowFunctionExpression","messageId":"missingReturnType","endLine":4,"endColumn":43},{"ruleId":"@typescript-eslint/explicit-function-return-type","severity":2,"message":"Missing return type on function.","line":25,"column":74,"nodeType":"ArrowFunctionExpression","messageId":"missingReturnType","endLine":25,"endColumn":76},{"ruleId":"@typescript-eslint/explicit-function-return-type","severity":2,"message":"Missing return type on function.","line":33,"column":33,"nodeType":"ArrowFunctionExpression","messageId":"missingReturnType","endLine":33,"endColumn":35},{"ruleId":"@typescript-eslint/explicit-function-return-type","severity":2,"message":"Missing return type on function.","line":44,"column":34,"nodeType":"ArrowFunctionExpression","messageId":"missingReturnType","endLine":44,"endColumn":36},{"ruleId":"@typescript-eslint/explicit-function-return-type","severity":2,"message":"Missing return type on function.","line":60,"column":29,"nodeType":"ArrowFunctionExpression","messageId":"missingReturnType","endLine":60,"endColumn":31},{"ruleId":"@typescript-eslint/explicit-function-return-type","severity":2,"message":"Missing return type on function.","line":71,"column":45,"nodeType":"ArrowFunctionExpression","messageId":"missingReturnType","endLine":71,"endColumn":47},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'e' is defined but never used.","line":100,"column":14,"nodeType":null,"messageId":"unusedVar","endLine":100,"endColumn":15},{"ruleId":"@typescript-eslint/explicit-function-return-type","severity":2,"message":"Missing return type on function.","line":106,"column":40,"nodeType":"ArrowFunctionExpression","messageId":"missingReturnType","endLine":106,"endColumn":42},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'e' is defined but never used.","line":114,"column":14,"nodeType":null,"messageId":"unusedVar","endLine":114,"endColumn":15},{"ruleId":"@typescript-eslint/explicit-function-return-type","severity":2,"message":"Missing return type on function.","line":121,"column":26,"nodeType":"ArrowFunctionExpression","messageId":"missingReturnType","endLine":121,"endColumn":28},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'e' is defined but never used.","line":128,"column":14,"nodeType":null,"messageId":"unusedVar","endLine":128,"endColumn":15},{"ruleId":"@typescript-eslint/explicit-function-return-type","severity":2,"message":"Missing return type on function.","line":135,"column":20,"nodeType":"ArrowFunctionExpression","messageId":"missingReturnType","endLine":135,"endColumn":22},{"ruleId":"@typescript-eslint/explicit-function-return-type","severity":2,"message":"Missing return type on function.","line":148,"column":33,"nodeType":"ArrowFunctionExpression","messageId":"missingReturnType","endLine":148,"endColumn":35}],"suppressedMessages":[],"errorCount":13,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect } from 'react'\nimport { Evrak } from '../models/evrak-types'\n\nexport const useResmiYaziViewModel = () => {\n  const [liste, setListe] = useState<Evrak[]>([])\n  const [arama, setArama] = useState('')\n\n  // UI Durumlar─▒\n  const [modalAcik, setModalAcik] = useState(false)\n  const [yukleniyor, setYukleniyor] = useState(false)\n  const [bildirim, setBildirim] = useState<{ mesaj: string; tur: 'basari' | 'hata' } | null>(null)\n  const [silinecekId, setSilinecekId] = useState<number | null>(null)\n\n  const [formData, setFormData] = useState<Evrak>({\n    tur: 'Giden Evrak',\n    tarih: new Date().toLocaleDateString('tr-TR'),\n    sayi: '',\n    kurum: '',\n    konu: '',\n    dosya_yolu: '',\n    durum: 'Cevap Gerekmiyor'\n  })\n\n  // Bildirim G├Âsterici\n  const mesajGoster = (mesaj: string, tur: 'basari' | 'hata' = 'basari') => {\n    setBildirim({ mesaj, tur })\n    setTimeout(() => setBildirim(null), 3000)\n  }\n\n  // Kurum Listesi\n  const [kurumListesi, setKurumListesi] = useState<{ id: number; ad: string }[]>([])\n\n  const kurumListele = async () => {\n    try {\n      if (window.api) {\n        const data = await window.api.getKurumTanimlari()\n        setKurumListesi(data)\n      }\n    } catch {\n      // sessiz\n    }\n  }\n\n  const verileriGetir = async () => {\n    try {\n      if (window.api && window.api.getEvraklar) {\n        const data = await window.api.getEvraklar()\n        setListe(data)\n      }\n    } catch (e) {\n      console.error(e)\n    }\n  }\n\n  useEffect(() => {\n    verileriGetir()\n    kurumListele()\n  }, [])\n\n  const dosyaSec = async () => {\n    try {\n      if (window.api) {\n        const path = await window.api.selectFile()\n        if (path) setFormData({ ...formData, dosya_yolu: path })\n      }\n    } catch (e) {\n      console.error(e)\n    }\n  }\n\n  const kaydet = async (e: React.FormEvent) => {\n    e.preventDefault()\n    if (!formData.kurum || !formData.konu) return mesajGoster('Kurum ve Konu zorunludur!', 'hata')\n\n    // Kurum kontrol├╝ ve otomatik ekleme\n    const girilenKurum = formData.kurum.toUpperCase()\n    const kurumMevcut = kurumListesi.find((k) => k.ad === girilenKurum)\n\n    if (!kurumMevcut && window.api) {\n      try {\n        await window.api.addKurumTanim(girilenKurum)\n        kurumListele() // Listeyi g├╝ncelle\n      } catch (e) {\n        console.error('Kurum otomatik eklenemedi', e)\n      }\n    }\n\n    try {\n      if (window.api) {\n        if (formData.id) {\n          await window.api.updateEvrak({ ...formData, kurum: girilenKurum })\n          mesajGoster('Evrak g├╝ncellendi.')\n        } else {\n          await window.api.addEvrak({ ...formData, kurum: girilenKurum })\n          mesajGoster('Yeni evrak eklendi.')\n        }\n        setModalAcik(false)\n        verileriGetir()\n      }\n    } catch (e) {\n      mesajGoster('─░┼şlem hatas─▒.', 'hata')\n    }\n  }\n\n  // Silme Onay─▒\n  const silmeIsleminiOnayla = async () => {\n    if (silinecekId === null) return\n    try {\n      if (window.api) {\n        await window.api.deleteEvrak(silinecekId)\n        mesajGoster('Kay─▒t silindi.', 'basari')\n        verileriGetir()\n      }\n    } catch (e) {\n      mesajGoster('Silme hatas─▒.', 'hata')\n    } finally {\n      setSilinecekId(null)\n    }\n  }\n\n  const pdfAl = async () => {\n    setYukleniyor(true)\n    try {\n      if (window.api) {\n        await window.api.createPdfResmiYazi(liste)\n        mesajGoster('PDF Olu┼şturuldu.', 'basari')\n      }\n    } catch (e) {\n      mesajGoster('PDF Hatas─▒.', 'hata')\n    } finally {\n      setYukleniyor(false)\n    }\n  }\n\n  const onNew = () => {\n    setFormData({\n      tur: 'Giden Evrak',\n      tarih: new Date().toLocaleDateString('tr-TR'),\n      sayi: '',\n      kurum: '',\n      konu: '',\n      dosya_yolu: '',\n      durum: 'Cevap Gerekmiyor'\n    })\n    setModalAcik(true)\n  }\n\n  const onEdit = (evrak: Evrak) => {\n    setFormData(evrak)\n    setModalAcik(true)\n  }\n\n  const filtrelenmis = liste.filter(\n    (x) =>\n      x.konu.toLowerCase().includes(arama.toLowerCase()) ||\n      x.kurum.toLowerCase().includes(arama.toLowerCase())\n  )\n\n  return {\n    liste,\n    arama,\n    setArama,\n    modalAcik,\n    setModalAcik,\n    yukleniyor,\n    bildirim,\n    silinecekId,\n    setSilinecekId,\n    formData,\n    setFormData,\n    filtrelenmis,\n    onNew,\n    onEdit,\n    dosyaSec,\n    kaydet,\n    silmeIsleminiOnayla,\n    pdfAl,\n    verileriGetir,\n    kurumListesi\n  }\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\hakan\\Desktop\\my-super-app\\src\\renderer\\src\\modules\\resmi_yazi\\views\\ResmiYazi.tsx","messages":[{"ruleId":"@typescript-eslint/explicit-function-return-type","severity":2,"message":"Missing return type on function.","line":8,"column":29,"nodeType":"ArrowFunctionExpression","messageId":"missingReturnType","endLine":8,"endColumn":31}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { Search, CheckCircle, AlertCircle } from 'lucide-react'\nimport { useResmiYaziViewModel } from '../viewmodels/useResmiYaziViewModel'\nimport { EvrakHeader } from '../components/EvrakHeader'\nimport { EvrakListTable } from '../components/EvrakListTable'\nimport { EvrakFormModal } from '../components/EvrakFormModal'\nimport { EvrakDeleteModal } from '../components/EvrakDeleteModal'\n\nexport const ResmiYazi = () => {\n  const vm = useResmiYaziViewModel()\n\n  return (\n    <div className=\"flex flex-col h-full bg-gray-50/50 dark:bg-gray-900 relative overflow-hidden\">\n      {/* B─░LD─░R─░M ├çUBU─ŞU */}\n      {vm.bildirim && (\n        <div\n          className={`absolute top-4 left-1/2 transform -translate-x-1/2 z-[60] px-6 py-3 rounded-lg shadow-lg flex items-center gap-3 transition-all duration-300 ${vm.bildirim.tur === 'basari' ? 'bg-green-600' : 'bg-red-600'} text-white`}\n        >\n          {vm.bildirim.tur === 'basari' ? <CheckCircle size={20} /> : <AlertCircle size={20} />}\n          <span className=\"font-medium\">{vm.bildirim.mesaj}</span>\n        </div>\n      )}\n\n      {/* S─░LME ONAY MODALI */}\n      <EvrakDeleteModal\n        isOpen={vm.silinecekId !== null}\n        onClose={() => vm.setSilinecekId(null)}\n        onConfirm={vm.silmeIsleminiOnayla}\n      />\n\n      {/* ├£st Bar */}\n      <EvrakHeader onPrint={vm.pdfAl} onNew={vm.onNew} yukleniyor={vm.yukleniyor} />\n\n      {/* Liste */}\n      <div className=\"flex-1 overflow-hidden flex flex-col\">\n        <div className=\"mx-6 mt-4 relative\">\n          <Search className=\"absolute left-3 top-2.5 text-gray-400\" size={18} />\n          <input\n            className=\"w-full pl-10 p-2.5 border rounded-xl outline-none focus:ring-2 focus:ring-blue-500 shadow-sm bg-white dark:bg-gray-800 dark:border-gray-700 dark:text-white\"\n            placeholder=\"Konu veya Kurum ara...\"\n            value={vm.arama}\n            onChange={(e) => vm.setArama(e.target.value)}\n          />\n        </div>\n\n        <EvrakListTable\n          data={vm.filtrelenmis}\n          onOpenFile={(path) => window.api.openFile(path)}\n          onEdit={vm.onEdit}\n          onDelete={vm.setSilinecekId}\n        />\n      </div>\n\n      {/* Kay─▒t Modal─▒ */}\n      <EvrakFormModal\n        isOpen={vm.modalAcik}\n        onClose={() => vm.setModalAcik(false)}\n        onSave={vm.kaydet}\n        formData={vm.formData}\n        setFormData={vm.setFormData}\n        onFileSelect={vm.dosyaSec}\n        kurumListesi={vm.kurumListesi}\n      />\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\hakan\\Desktop\\my-super-app\\src\\renderer\\src\\modules\\settings\\components\\SettingsForm.tsx","messages":[{"ruleId":"@typescript-eslint/explicit-function-return-type","severity":2,"message":"Missing return type on function.","line":10,"column":96,"nodeType":"ArrowFunctionExpression","messageId":"missingReturnType","endLine":10,"endColumn":98}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { User, Save } from 'lucide-react'\n\ninterface SettingsFormProps {\n  username: string\n  setUsername: (val: string) => void\n  onSave: () => void\n  yukleniyor: boolean\n}\n\nexport const SettingsForm = ({ username, setUsername, onSave, yukleniyor }: SettingsFormProps) => {\n  return (\n    <div className=\"bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden\">\n      <div className=\"p-6 space-y-6\">\n        <div>\n          <label className=\"block text-sm font-bold text-gray-700 mb-2 flex items-center gap-2\">\n            <User size={16} className=\"text-gray-400\" /> Kullan─▒c─▒ Ad─▒\n          </label>\n          <input\n            type=\"text\"\n            className=\"w-full p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none transition\"\n            placeholder=\"Ad─▒n─▒z Soyad─▒n─▒z\"\n            value={username}\n            onChange={(e) => setUsername(e.target.value)}\n          />\n          <p className=\"text-xs text-gray-400 mt-1\">\n            Bu isim raporlarda ve program ba┼şl─▒─ş─▒nda g├Âr├╝necektir.\n          </p>\n        </div>\n      </div>\n\n      <div className=\"bg-gray-50 p-4 border-t border-gray-100 flex justify-end\">\n        <button\n          onClick={onSave}\n          disabled={yukleniyor}\n          className=\"bg-blue-600 hover:bg-blue-700 text-white px-6 py-2.5 rounded-lg font-bold shadow-md flex items-center gap-2 transition transform active:scale-95\"\n        >\n          <Save size={18} />\n          {yukleniyor ? 'Kaydediliyor...' : 'De─şi┼şiklikleri Kaydet'}\n        </button>\n      </div>\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\hakan\\Desktop\\my-super-app\\src\\renderer\\src\\modules\\settings\\components\\SettingsHeader.tsx","messages":[{"ruleId":"@typescript-eslint/explicit-function-return-type","severity":2,"message":"Missing return type on function.","line":3,"column":34,"nodeType":"ArrowFunctionExpression","messageId":"missingReturnType","endLine":3,"endColumn":36}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { Settings } from 'lucide-react'\n\nexport const SettingsHeader = () => {\n  return (\n    <div className=\"flex items-center gap-3 mb-8\">\n      <div className=\"p-3 bg-blue-100 dark:bg-blue-900/40 text-blue-600 dark:text-blue-400 rounded-xl transition-colors\">\n        <Settings size={32} />\n      </div>\n      <div>\n        <h1 className=\"text-2xl font-bold text-gray-800 dark:text-gray-100 transition-colors\">\n          Uygulama Ayarlar─▒\n        </h1>\n        <p className=\"text-gray-500 dark:text-gray-400 text-sm transition-colors\">\n          Ki┼şisel tercihlerinizi buradan y├Ânetebilirsiniz.\n        </p>\n      </div>\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\hakan\\Desktop\\my-super-app\\src\\renderer\\src\\modules\\settings\\viewmodels\\useSettingsViewModel.ts","messages":[{"ruleId":"@typescript-eslint/explicit-function-return-type","severity":2,"message":"Missing return type on function.","line":4,"column":40,"nodeType":"ArrowFunctionExpression","messageId":"missingReturnType","endLine":4,"endColumn":42},{"ruleId":"@typescript-eslint/explicit-function-return-type","severity":2,"message":"Missing return type on function.","line":10,"column":74,"nodeType":"ArrowFunctionExpression","messageId":"missingReturnType","endLine":10,"endColumn":76},{"ruleId":"@typescript-eslint/explicit-function-return-type","severity":2,"message":"Missing return type on function.","line":15,"column":34,"nodeType":"ArrowFunctionExpression","messageId":"missingReturnType","endLine":15,"endColumn":36},{"ruleId":"@typescript-eslint/explicit-function-return-type","severity":2,"message":"Missing return type on function.","line":77,"column":34,"nodeType":"ArrowFunctionExpression","messageId":"missingReturnType","endLine":77,"endColumn":36},{"ruleId":"@typescript-eslint/explicit-function-return-type","severity":2,"message":"Missing return type on function.","line":88,"column":41,"nodeType":"ArrowFunctionExpression","messageId":"missingReturnType","endLine":88,"endColumn":43},{"ruleId":"@typescript-eslint/explicit-function-return-type","severity":2,"message":"Missing return type on function.","line":101,"column":40,"nodeType":"ArrowFunctionExpression","messageId":"missingReturnType","endLine":101,"endColumn":42},{"ruleId":"@typescript-eslint/explicit-function-return-type","severity":2,"message":"Missing return type on function.","line":118,"column":41,"nodeType":"ArrowFunctionExpression","messageI