,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect } from 'react'\nimport { ToastType } from '../../../shared/components/Toast'\nimport { Personel } from '../models/personel-terfi-types'\n\nexport const usePersonelTerfiViewModel = () => {\n  const [personeller, setPersoneller] = useState<Personel[]>([])\n  const [arama, setArama] = useState('')\n  const [secilenler, setSecilenler] = useState<number[]>([])\n  const [yukleniyor, setYukleniyor] = useState(false)\n\n  // Toast State\n  const [toast, setToast] = useState<{ show: boolean; message: string; type: ToastType }>({\n    show: false,\n    message: '',\n    type: 'success'\n  })\n\n  // Toast Helper\n  const showToast = (type: ToastType, message: string): void => {\n    setToast({ show: true, type, message })\n  }\n\n  const verileriGetir = async (): Promise<void> => {\n    try {\n      if (window.api) {\n        const data = await window.api.getPersoneller()\n        setPersoneller(data)\n      }\n    } catch (e) {\n      console.error(e)\n      showToast('error', 'Personel listesi al─▒namad─▒.')\n    }\n  }\n\n  useEffect(() => {\n    verileriGetir()\n    // eslint-disable-next-line react-hooks/exhaustive-deps\n  }, [])\n\n  const filtrelenenler = personeller.filter((p) =>\n    p.ad_soyad.toLowerCase().includes(arama.toLowerCase())\n  )\n\n  // Se├ğim\n  const tumunuSec = (): void => {\n    if (secilenler.length === filtrelenenler.length) setSecilenler([])\n    else setSecilenler(filtrelenenler.map((p) => p.id))\n  }\n\n  const tekSec = (id: number): void => {\n    if (secilenler.includes(id)) setSecilenler(secilenler.filter((sid) => sid !== id))\n    else setSecilenler([...secilenler, id])\n  }\n\n  // Modal State\n  const [modalAcik, setModalAcik] = useState(false)\n  const [duzenlenecekPersonel, setDuzenlenecekPersonel] = useState<Personel | null>(null)\n\n  // --- PDF RAPORLAMA ---\n  const raporAl = async (): Promise<void> => {\n    setYukleniyor(true)\n    try {\n      let veri: Personel[] = []\n\n      // TERFI_LISTESI: Filtrelenmi┼ş ve ekranda g├Âr├╝nen (veya hak kazanan?) personeli yazd─▒r─▒r.\n      // Kullan─▒c─▒ \"Se├ğilenler\" mant─▒─ş─▒n─▒ kald─▒rd─▒─ş─▒ i├ğin do─şrudan listedeki herkesi veya terfi hak edenleri alabiliriz.\n      // ┼Şimdilik filtrelenmi┼ş listeyi baz alal─▒m.\n      veri = filtrelenenler\n\n      if (window.api) {\n        // Backend taraf─▒nda 'TERFI_LISTESI' tipini kar┼ş─▒layan logic olmal─▒, yoksa 'TERFI' olarak g├Ânderip t├╝m listeyi mi verelim?\n        // G├╝venli olmas─▒ i├ğin 'TERFI' tipini kullan─▒p t├╝m listeyi g├Ânderelim.\n        const resultStr = await window.api.createPdfTerfi({\n          tip: 'TERFI', // Backend bu tipi biliyor\n          liste: veri\n        })\n\n        try {\n          const res = JSON.parse(resultStr)\n          if (res.success) {\n            await window.api.openFile(res.path)\n            showToast('success', 'PDF olu┼şturuldu ve a├ğ─▒l─▒yor.')\n          } else {\n            throw new Error(res.error || 'PDF olu┼şturulamad─▒.')\n          }\n        } catch (err: any) {\n          console.error('PDF Yan─▒t Hatas─▒:', err)\n          // E─şer JSON de─şilse veya parse hatas─▒ ise\n          if (err instanceof SyntaxError) {\n            throw new Error('PDF motorundan ge├ğersiz yan─▒t al─▒nd─▒.')\n          }\n          throw err\n        }\n      }\n    } catch (e: any) {\n      console.error('PDF Hatas─▒:', e)\n      // Hata mesaj─▒n─▒ backend'den al veya varsay─▒lan g├Âster\n      const errMsg = e.message || e.toString() || 'Yazd─▒rma i┼şlemi s─▒ras─▒nda bir hata olu┼ştu.'\n      showToast('error', errMsg.includes('Python') ? 'Python motoru ba┼şlat─▒lamad─▒.' : errMsg)\n    } finally {\n      setYukleniyor(false)\n    }\n  }\n\n  const duzenlemeyiBaslat = (personel: Personel | null) => {\n    setDuzenlenecekPersonel(personel)\n    setModalAcik(true)\n  }\n\n  const personelKaydet = async (data: any) => {\n    try {\n      if (window.api) {\n        if (duzenlenecekPersonel && duzenlenecekPersonel.id) {\n          // G├£NCELLEME\n          await window.api.updatePersonel({ ...data, id: duzenlenecekPersonel.id })\n          showToast('success', 'Personel g├╝ncellendi.')\n        } else {\n          // EKLEME\n          await window.api.addPersonel(data)\n          showToast('success', 'Personel eklendi.')\n        }\n        setModalAcik(false)\n        setDuzenlenecekPersonel(null)\n        verileriGetir()\n      }\n    } catch {\n      showToast('error', '─░┼şlem s─▒ras─▒nda hata olu┼ştu.')\n    }\n  }\n\n  return {\n    personeller,\n    arama,\n    setArama,\n    secilenler,\n    yukleniyor,\n    toast,\n    setToast,\n    filtrelenenler,\n    tumunuSec,\n    tekSec,\n    raporAl,\n    modalAcik,\n    setModalAcik,\n    personelKaydet, // ─░sim de─şi┼şti: personelEkle -> personelKaydet\n    duzenlenecekPersonel,\n    duzenlemeyiBaslat\n  }\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\hakan\\Desktop\\my-super-app\\src\\renderer\\src\\modules\\personel_terfi\\views\\PersonelTerfi.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\hakan\\Desktop\\my-super-app\\src\\renderer\\src\\modules\\posta_zimmet\\components\\ZimmetArsivListe.tsx","messages":[{"ruleId":"@typescript-eslint/explicit-function-return-type","severity":2,"message":"Missing return type on function.","line":20,"column":27,"nodeType":"ArrowFunctionExpression","messageId":"missingReturnType","endLine":20,"endColumn":29}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { History, Search, Trash2 } from 'lucide-react'\nimport { ZimmetKayit } from '../models/zimmet-types'\n\ninterface ZimmetArsivListeProps {\n  arsivListe: ZimmetKayit[]\n  arama: string\n  setArama: (val: string) => void\n  onSearch: (val: string) => void\n  onDelete: (id: number) => void\n  onToggleStatus: (item: ZimmetKayit) => void\n}\n\nexport const ZimmetArsivListe = ({\n  arsivListe,\n  arama,\n  setArama,\n  onSearch,\n  onDelete,\n  onToggleStatus\n}: ZimmetArsivListeProps) => {\n  return (\n    <div className=\"w-[65%] flex flex-col bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm overflow-hidden\">\n      <div className=\"p-4 border-b dark:border-gray-700 flex justify-between items-center gap-4 bg-gray-50 dark:bg-gray-800/50\">\n        <div className=\"flex items-center gap-2 text-gray-700 dark:text-gray-200 font-bold\">\n          <History size={20} className=\"text-orange-500\" /> Ge├ğmi┼ş Kay─▒tlar\n        </div>\n        <div className=\"relative flex-1 max-w-sm\">\n          <Search className=\"absolute left-3 top-2.5 text-gray-400\" size={16} />\n          <input\n            className=\"w-full pl-9 p-2 border dark:border-gray-600 rounded-lg text-sm bg-white dark:bg-gray-700 dark:text-white focus:outline-none focus:border-blue-500\"\n            placeholder=\"Ara...\"\n            value={arama}\n            onChange={(e) => {\n              setArama(e.target.value)\n              onSearch(e.target.value)\n            }}\n          />\n        </div>\n      </div>\n      <div className=\"flex-1 overflow-auto\">\n        <table className=\"w-full text-sm text-left\">\n          <thead className=\"bg-orange-50 dark:bg-orange-900/20 text-orange-800 dark:text-orange-300 font-bold text-xs sticky top-0 z-10 shadow-sm\">\n            <tr>\n              <th className=\"p-3 text-center\">Durum</th>\n              <th className=\"p-3\">Tarih</th>\n              <th className=\"p-3\">Barkod</th>\n              <th className=\"p-3\">Evrak No</th>\n              <th className=\"p-3\">Gidece─şi Yer</th>\n              <th className=\"p-3 text-right\">Tutar</th>\n              <th className=\"p-3 text-center\">Sil</th>\n            </tr>\n          </thead>\n          <tbody className=\"divide-y dark:divide-gray-700\">\n            {arsivListe.length === 0 ? (\n              <tr>\n                <td colSpan={7} className=\"p-10 text-center text-gray-400\">\n                  Kay─▒t bulunamad─▒.\n                </td>\n              </tr>\n            ) : (\n              arsivListe.map((item) => (\n                <tr key={item.id} className=\"hover:bg-gray-50 dark:hover:bg-gray-700/30 transition\">\n                  <td className=\"p-3 text-center\">\n                    <button\n                      onClick={() => onToggleStatus(item)}\n                      className={`flex items-center justify-center w-full py-1 rounded text-[10px] font-bold border ${item.durum === 'GELD─░' ? 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 border-green-200 dark:border-green-800' : 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-300 border-yellow-200 dark:border-yellow-800'}`}\n                    >\n                      {item.durum === 'GELD─░' ? 'GELD─░' : 'BEKL─░YOR'}\n                    </button>\n                  </td>\n                  <td className=\"p-3 text-gray-600 dark:text-gray-400 text-xs whitespace-nowrap\">\n                    {item.tarih.split(' ')[0]}\n                  </td>\n                  <td className=\"p-3 font-mono text-blue-600 dark:text-blue-400 font-medium\">\n                    {item.barkod}\n                  </td>\n                  <td className=\"p-3 text-gray-700 dark:text-gray-300\">{item.evrak_no}</td>\n                  <td className=\"p-3 font-medium text-gray-800 dark:text-gray-200\">{item.yer}</td>\n                  <td className=\"p-3 text-right font-medium text-gray-700 dark:text-gray-300\">\n                    {item.ucret.toFixed(2)}\n                  </td>\n                  <td className=\"p-3 text-center\">\n                    <button\n                      onClick={() => onDelete(item.id!)}\n                      className=\"text-gray-300 hover:text-red-500 transition p-1\"\n                    >\n                      <Trash2 size={16} />\n                    </button>\n                  </td>\n                </tr>\n              ))\n            )}\n          </tbody>\n        </table>\n      </div>\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\hakan\\Desktop\\my-super-app\\src\\renderer\\src\\modules\\posta_zimmet\\components\\ZimmetGirisForm.tsx","messages":[{"ruleId":"@typescript-eslint/explicit-function-return-type","severity":2,"message":"Missing return type on function.","line":28,"column":26,"nodeType":"ArrowFunctionExpression","messageId":"missingReturnType","endLine":28,"endColumn":28}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { Plus, FileText } from 'lucide-react'\nimport { FormEvent } from 'react'\n\ninterface ZimmetGirisFormProps {\n  evrakNo: string\n  setEvrakNo: (val: string) => void\n  barkod: string\n  setBarkod: (val: string) => void\n  yer: string\n  setYer: (val: string) => void\n  ucret: string\n  setUcret: (val: string) => void\n  onAdd: (e: FormEvent) => void\n  kurumListesi?: { id: number; ad: string }[]\n}\n\nexport const ZimmetGirisForm = ({\n  evrakNo,\n  setEvrakNo,\n  barkod,\n  setBarkod,\n  yer,\n  setYer,\n  ucret,\n  setUcret,\n  onAdd,\n  kurumListesi = []\n}: ZimmetGirisFormProps) => {\n  return (\n    <div className=\"bg-white dark:bg-gray-800 p-4 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm\">\n      <div className=\"flex items-center gap-2 mb-3 text-blue-700 dark:text-blue-400 font-bold border-b dark:border-gray-700 pb-2\">\n        <FileText size={18} /> Evrak Giri┼şi\n      </div>\n      <form onSubmit={onAdd} className=\"space-y-3\">\n        <div>\n          <label className=\"text-xs font-bold text-gray-500 dark:text-gray-400\">Evrak No</label>\n          <input\n            className=\"w-full border dark:border-gray-600 p-2 rounded-lg text-sm bg-white dark:bg-gray-700 dark:text-white focus:border-blue-500 outline-none\"\n            value={evrakNo}\n            onChange={(e) => setEvrakNo(e.target.value)}\n            placeholder=\"Say─▒...\"\n            autoFocus\n          />\n        </div>\n        <div>\n          <label className=\"text-xs font-bold text-gray-500 dark:text-gray-400\">Barkod</label>\n          <input\n            className=\"w-full border dark:border-gray-600 p-2 rounded-lg text-sm font-mono uppercase bg-white dark:bg-gray-700 dark:text-white focus:border-blue-500 outline-none\"\n            value={barkod}\n            onChange={(e) => setBarkod(e.target.value.toUpperCase())}\n            placeholder=\"RR...\"\n            maxLength={13}\n          />\n        </div>\n        <div>\n          <label className=\"text-xs font-bold text-gray-500 dark:text-gray-400\">Gidece─şi Yer</label>\n          <input\n            className=\"w-full border dark:border-gray-600 p-2 rounded-lg text-sm uppercase bg-white dark:bg-gray-700 dark:text-white focus:border-blue-500 outline-none\"\n            value={yer}\n            onChange={(e) => setYer(e.target.value.toUpperCase())}\n            placeholder=\"Kurum/Ki┼şi Ad─▒...\"\n            list=\"kurumlar\"\n          />\n          <datalist id=\"kurumlar\">\n            {kurumListesi.map((k) => (\n              <option key={k.id} value={k.ad} />\n            ))}\n          </datalist>\n        </div>\n        <div>\n          <label className=\"text-xs font-bold text-gray-500 dark:text-gray-400\">├£cret</label>\n          <input\n            type=\"number\"\n            step=\"0.1\"\n            className=\"w-full border dark:border-gray-600 p-2 rounded-lg text-sm bg-white dark:bg-gray-700 dark:text-white focus:border-blue-500 outline-none\"\n            value={ucret}\n            onChange={(e) => setUcret(e.target.value)}\n          />\n        </div>\n        <button className=\"w-full bg-blue-600 hover:bg-blue-700 text-white py-2 rounded-lg font-bold shadow flex justify-center items-center gap-2\">\n          <Plus size={18} /> Listeye Ekle\n        </button>\n      </form>\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\hakan\\Desktop\\my-super-app\\src\\renderer\\src\\modules\\posta_zimmet\\components\\ZimmetModals.tsx","messages":[{"ruleId":"@typescript-eslint/explicit-function-return-type","severity":2,"message":"Missing return type on function.","line":15,"column":28,"nodeType":"ArrowFunctionExpression","messageId":"missingReturnType","endLine":15,"endColumn":30},{"ruleId":"@typescript-eslint/explicit-function-return-type","severity":2,"message":"Missing return type on function.","line":59,"column":26,"nodeType":"ArrowFunctionExpression","messageId":"missingReturnType","endLine":59,"endColumn":28}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { Trash2, Save } from 'lucide-react'\n\ninterface ZimmetDeleteModalProps {\n  isOpen: boolean\n  onClose: () => void\n  onConfirm: () => void\n  isArchive: boolean\n}\n\nexport const ZimmetDeleteModal = ({\n  isOpen,\n  onClose,\n  onConfirm,\n  isArchive\n}: ZimmetDeleteModalProps) => {\n  if (!isOpen) return null\n\n  return (\n    <div className=\"absolute inset-0 bg-black/50 z-[70] flex items-center justify-center p-4 backdrop-blur-sm\">\n      <div className=\"bg-white rounded-xl shadow-2xl p-6 w-80 text-center\">\n        <div className=\"w-12 h-12 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4 text-red-600\">\n          <Trash2 size={24} />\n        </div>\n        <h3 className=\"text-lg font-bold text-gray-800 mb-2\">Emin misiniz?</h3>\n        <p className=\"text-gray-500 text-sm mb-6\">\n          {isArchive ? 'Bu kay─▒t kal─▒c─▒ olarak silinecek.' : 'Bu kay─▒t listeden ├ğ─▒kar─▒lacak.'}\n        </p>\n        <div className=\"flex gap-3\">\n          <button\n            onClick={onClose}\n            className=\"flex-1 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-lg font-bold\"\n          >\n            Vazge├ğ\n          </button>\n          <button\n            onClick={onConfirm}\n            className=\"flex-1 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg font-bold\"\n          >\n            Sil\n          </button>\n        </div>\n      </div>\n    </div>\n  )\n}\n\ninterface ZimmetSaveModalProps {\n  isOpen: boolean\n  onClose: () => void\n  onConfirm: () => void\n  itemCount: number\n}\n\nexport const ZimmetSaveModal = ({\n  isOpen,\n  onClose,\n  onConfirm,\n  itemCount\n}: ZimmetSaveModalProps) => {\n  if (!isOpen) return null\n\n  return (\n    <div className=\"absolute inset-0 bg-black/50 z-[70] flex items-center justify-center p-4 backdrop-blur-sm\">\n      <div className=\"bg-white rounded-xl shadow-2xl p-6 w-80 text-center\">\n        <div className=\"w-12 h-12 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4 text-green-600\">\n          <Save size={24} />\n        </div>\n        <h3 className=\"text-lg font-bold text-gray-800 mb-2\">Kaydet ve Yazd─▒r?</h3>\n        <p className=\"text-gray-500 text-sm mb-6\">\n          {itemCount} adet evrak kaydedilip PDF olu┼şturulacak.\n        </p>\n        <div className=\"flex gap-3\">\n          <button\n            onClick={onClose}\n            className=\"flex-1 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-lg font-bold\"\n          >\n            ─░ptal\n          </button>\n          <button\n            onClick={onConfirm}\n            className=\"flex-1 py-2 bg-green-600 hover:bg-green-700 text-white rounded-lg font-bold\"\n          >\n            Onayla\n          </button>\n        </div>\n      </div>\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\hakan\\Desktop\\my-super-app\\src\\renderer\\src\\modules\\posta_zimmet\\components\\ZimmetYazdirListe.tsx","messages":[{"ruleId":"@typescri